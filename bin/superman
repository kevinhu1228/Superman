#!/usr/bin/env bash
# Resolve the real path of this script portably (macOS/BSD readlink has no -f flag)
_self="$0"
while [ -L "$_self" ]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _link="$(readlink "$_self")"
  case "$_link" in /*) _self="$_link" ;; *) _self="$_dir/$_link" ;; esac
done
_scripts="$(cd "$(dirname "$_self")/.." && pwd)/scripts"
if [ ! -f "$_scripts/install.sh" ]; then
  echo "superman: cannot locate scripts/install.sh (resolved to $_scripts/install.sh)" >&2
  echo "  If superman was installed via hardlink, re-install with: npm install -g" >&2
  exit 1
fi

case "${1:-}" in
  update)
    shift
    exec "$_scripts/update.sh" "$@"
    ;;
  init)
    shift
    _target="${1:-$(pwd)}"
    [ -d "$_target/.superman" ] && "$_scripts/check-version.sh" "$_target" 2>/dev/null || true
    exec "$_scripts/install.sh" "$@"
    ;;
  *)
    _target="${1:-$(pwd)}"
    [ -d "$_target/.superman" ] && "$_scripts/check-version.sh" "$_target" 2>/dev/null || true
    exec "$_scripts/install.sh" "$@"
    ;;
esac
